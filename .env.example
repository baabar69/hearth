# Hearth — payments env vars.
# Copy to .env.local and fill in real values.
# .env.local is gitignored; .env.example is committed as a template.

# ─── Whop API (server-only — NEVER prefix with NEXT_PUBLIC_) ─────────────────
# Find at: https://whop.com/dashboard/developer
WHOP_API_KEY=whop_xxxxxxxxxxxxxxxxxxxxxxxxx

# Find at: https://whop.com/dashboard → Webhooks → click your webhook → "Signing secret"
WHOP_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Whop checkout config (NEXT_PUBLIC_ = exposed to client bundle) ──────────
# "sandbox" enables test cards (4242…); "production" requires real cards.
# Sandbox requires:
#   1. A separate account at https://sandbox.whop.com
#   2. Sandbox plan IDs created in that account (different from production)
#   3. A sandbox API key from https://sandbox.whop.com/dashboard/developer
# When set to "sandbox", the server SDK auto-routes to https://sandbox-api.whop.com.
NEXT_PUBLIC_WHOP_ENVIRONMENT=production

# Plan IDs — get from: https://whop.com/dashboard → Checkout links → 3-dot menu → Details
NEXT_PUBLIC_HEARTHSIDE_PLAN_ID=plan_qMkY2ON1bgnbp
NEXT_PUBLIC_HEARTH_DEEP_PLAN_ID=plan_yOUyMLKC42oZI
NEXT_PUBLIC_HEARTHSIDE_ANNUAL_PLAN_ID=plan_3jx4Ci4VilnbW
NEXT_PUBLIC_HEARTH_DEEP_ANNUAL_PLAN_ID=plan_NvT1QMwnWj2up

# ─── App URL (used for post-checkout redirect) ───────────────────────────────
# Local dev: http://localhost:3000
# Production: https://your-domain.com (no trailing slash)
NEXT_PUBLIC_HEARTH_URL=http://localhost:3000

# ─── Intake form email delivery ──────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create. 100 emails/day on free tier.
# If RESEND_API_KEY is unset, /api/intake will log to console only (works in dev).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Where intake leads get emailed to (the founder / matching team).
INTAKE_NOTIFY_EMAIL=babar.ali69.ba@gmail.com

# Sender address for intake emails. Use "onboarding@resend.dev" until you
# verify a sending domain at https://resend.com/domains, then switch to e.g.
# "intake@dearhearth.com".
INTAKE_FROM_EMAIL=onboarding@resend.dev
